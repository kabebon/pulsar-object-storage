# Pulsar — Caddyfile.
# Reverse-proxies the app and terminates TLS automatically (Let's Encrypt).
# In local dev the default profile is not started; in production set the
# hostname below and `docker compose --profile prod up -d`.
#
# For custom-domain on-demand TLS (Phase 6) we use the `on_demand_tls` ask
# endpoint to verify a domain is registered before issuing a certificate.

{
	email admin@pulsar.my.id
	# Allow ACME HTTP-01 challenges.
	# On-demand issuance for customer domains:
	# Note: 'interval' and 'burst' were removed in Caddy 2.8+
	on_demand_tls {
		ask http://pulsar:8080/api/v1/domains/verify-tls
	}
}

# Public app.
{$PULSAR_HOST:pulsar.my.id} {
	reverse_proxy pulsar:8080 {
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
	encode zstd gzip
	log {
		output stdout
		format console
	}
}

# Storage / CDN front: serves the MinIO S3 API so browsers can PUT presigned
# uploads and GET downloads directly. Presigned URLs are signed against this
# host (S3_PUBLIC_ENDPOINT), so it MUST be reachable from the browser.
#
# Host header: intentionally NOT rewritten. Caddy proxies the incoming Host
# (cdn.pulsar.my.id) unchanged by default (v2.11+), which is exactly the host
# SigV4 signed the URL for. Rewriting it (header_up Host ...) would break the
# signature → 403 SignatureDoesNotMatch.
#
# To enable: add a DNS record for cdn.pulsar.my.id pointing at this host.
{$CDN_HOST:cdn.pulsar.my.id} {
	reverse_proxy minio:9000
	encode zstd gzip
	log {
		output stdout
		format console
	}
}

# Example of on-demand TLS for a customer domain (wildcard vhost):
# https:// {
# 	tls {
# 		get_certificate http://pulsar:8080/api/v1/domains/cert
# 	}
# 	reverse_proxy pulsar:8080
# }
