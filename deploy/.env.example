# Pulsar — example environment file.
# Copy to .env (next to docker-compose.yml) and adjust values.
#   cp deploy/.env.example .env

# --- Application ---
APP_ENV=local                      # local | production | test
APP_NAME=Pulsar
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
LOG_LEVEL=info                     # debug | info | warn | error
# Comma-separated CIDRs of trusted reverse proxies (Caddy / your load balancer).
# The app uses these to trust X-Forwarded-For / X-Real-IP headers. REQUIRED in
# production behind a proxy: without it the YooKassa webhook IP whitelist fails
# because r.RemoteAddr is the proxy's internal IP, not YooKassa's, so paid
# subscriptions are never applied.
# Docker default bridge/user networks use 172.16.0.0/12; add your proxy host too.
TRUSTED_PROXIES=172.16.0.0/12

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://pulsar:pulsar@localhost:5432/pulsar?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pulsar
S3_SECRET_KEY=pulsar12345
S3_BUCKET=pulsar
S3_USE_PATH_STYLE=true
S3_PRESIGN_EXPIRY=15m
# Public CDN host that clients use to upload/download files.
# When set, presigned URLs are signed against this host so S3_ENDPOINT (the
# origin) is never exposed to clients. For local dev, docker-compose defaults
# this to http://localhost:9000 (the host-exposed MinIO port) — leave it empty
# here to pick up that default. Set it explicitly only in production.
# Format: scheme + host, NO bucket path, NO trailing slash.
#   S3_PUBLIC_ENDPOINT=https://cdn.example.com
S3_PUBLIC_ENDPOINT=
# Comma-separated origins allowed to perform cross-origin PUT/GET against the
# bucket (the web uploader hits the storage host directly). Applied server-wide
# via MINIO_API_CORS_ALLOW_ORIGIN on the minio container — per-bucket CORS
# (`mc cors set`) is unavailable in the community MinIO build. Defaults to the
# local dev origins; set your app domain(s) in production:
#   CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# --- Security ---
JWT_SECRET=change-me-in-production-please-32-bytes-min
SESSION_COOKIE_NAME=pulsar_sid
SESSION_TTL=168h                    # 7 days
# IMPORTANT: behind a CDN traffic is HTTPS, so these MUST be true in production.
# Otherwise session/CSRF cookies leak over plain HTTP and CSRF protection breaks.
SESSION_COOKIE_SECURE=false
CSRF_SECURE=false

# --- Email (SMTP) ---
# Local dev: leave HOST=localhost / PORT=1025 (Mailpit, no auth needed).
# Production: set your SMTP provider credentials below.
#   Port 465  → implicit SSL  (common for most providers)
#   Port 587  → STARTTLS
#   Port 1025 → no TLS (Mailpit / local only)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Pulsar <no-reply@pulsar.my.id>

# --- Stripe (test mode) ---
# Leave empty to disable billing; the in-app billing page will run in
# "no-provider" mode (still shows plans + usage but skips Checkout).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_PRO=
STRIPE_PRICE_YEARLY_PRO=
STRIPE_PRICE_MONTHLY_BUSINESS=
STRIPE_PRICE_YEARLY_BUSINESS=

# --- YooKassa (RU payments — cards, SBP, YooMoney) ---
# Obtain credentials at https://yookassa.ru/my/shop-settings/integration
# Leave empty to disable; billing page shows/hides the YooKassa section automatically.
# Webhook URL to register in YooKassa dashboard: POST https://your-domain.com/webhooks/yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- CryptoBot / Crypto Pay (Telegram crypto payments — USDT, TON, BTC, etc.) ---
# Create your app via @CryptoBot → /pay → Create App to obtain a token.
# Register webhook in @CryptoBot: My Apps → [Your App] → Webhooks
# Webhook URL: POST https://your-domain.com/webhooks/cryptobot
# Network: "mainnet" (pay.crypt.bot) | "testnet" (testnet-pay.crypt.bot)
CRYPTOBOT_TOKEN=
CRYPTOBOT_NETWORK=mainnet

# --- Domains (production profile) ---
# PULSAR_HOST is the app domain Caddy fronts (PUBLIC_BASE_URL must match its
# scheme+host). CDN_HOST is the storage domain Caddy fronts MinIO on, so
# browsers can reach presigned upload/download URLs. Both need their own DNS
# A-records pointing at this server.
PULSAR_HOST=pulsar.my.id
CDN_HOST=cdn.pulsar.my.id

# --- CDN ---
CDN_DEFAULT_DOMAIN=cdn.localhost
CDN_SIGN_KEY=change-me-cdn-signKey
#
# Production upload setup checklist. The web uploader PUTs files DIRECTLY to the
# storage host via a presigned URL — that is cross-origin and must be reachable
# from the browser, so MinIO is fronted by a Caddy vhost on CDN_HOST. Set all of
# these together (in .env) when deploying the prod profile:
#
#   1. DNS                  → add an A-record for CDN_HOST (e.g. cdn.example.com)
#                            pointing at this server, same IP as PULSAR_HOST.
#   2. S3_PUBLIC_ENDPOINT   → the storage host browsers hit, with scheme and NO
#                            trailing slash, e.g. https://cdn.example.com
#                            (defaults to http://localhost:9000 for local dev).
#   3. CORS_ALLOWED_ORIGINS → the app origin(s) allowed cross-origin PUT/GET on
#                            MinIO, e.g. https://app.example.com (comma-separated).
#                            Applied server-wide via MINIO_API_CORS_ALLOW_ORIGIN.
#   4. SESSION_COOKIE_SECURE=true and CSRF_SECURE=true (traffic is HTTPS at Caddy).
#
# Caddy terminates TLS automatically (Let's Encrypt) for both domains and proxies
# cdn.<host> → minio:9000 WITHOUT rewriting the Host header. The Host reaching
# MinIO is therefore the same host SigV4 signed the URL against, so signatures
# validate. Rewriting Host would break it with HTTP 403 SignatureDoesNotMatch.
#
# Do NOT cache /app/* and /api/v1/* (user-specific). /static/* may be cached.

# --- Migrations ---
MIGRATIONS_DIR=migrations
